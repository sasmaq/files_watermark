{
    "name": "files_watermark/files_watermark",
    "description": "Nextcloud 31 file watermarking app",
    "type": "nextcloud-app",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.2",
        "setasign/fpdi": "^2.6",
        "tecnickcom/tcpdf": "^6.7"
    },
    "require-dev": {
        "nextcloud/ocp": "dev-stable31",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "OCA\\FilesWatermark\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\FilesWatermark\\Tests\\": "tests/"
        }
    },
    "config": {
        "vendor-dir": "vendor",
        "sort-packages": true
    }
}
